{
  "_comment": "Single source of truth for all DynamoDB table schemas. Key names derived from application code (crdt-service.js, social-api routes, lambda handlers). Consumed by Tiltfile, LocalStack bootstrap, and CDK stacks.",
  "tables": [
    {
      "tableName": "crdt-snapshots",
      "hashKey": { "name": "documentId", "type": "S" },
      "rangeKey": { "name": "timestamp", "type": "N" },
      "billing": "PAY_PER_REQUEST",
      "_note": "Hash key is documentId per _ensureTable(), retrieveLatestSnapshot(), and crdt-snapshot Lambda. NOTE: writeSnapshot direct-write path incorrectly uses 'channelId' attribute — that is a code bug to fix separately."
    },
    {
      "tableName": "crdt-documents",
      "hashKey": { "name": "documentId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "social-profiles",
      "hashKey": { "name": "userId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "social-relationships",
      "hashKey": { "name": "followerId", "type": "S" },
      "rangeKey": { "name": "followeeId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "followeeId-followerId-index",
          "hashKey": { "name": "followeeId", "type": "S" },
          "rangeKey": { "name": "followerId", "type": "S" },
          "projection": "ALL"
        }
      ]
    },
    {
      "tableName": "social-groups",
      "hashKey": { "name": "groupId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "social-group-members",
      "hashKey": { "name": "groupId", "type": "S" },
      "rangeKey": { "name": "userId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "social-rooms",
      "hashKey": { "name": "roomId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "social-room-members",
      "hashKey": { "name": "roomId", "type": "S" },
      "rangeKey": { "name": "userId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "userId-roomId-index",
          "hashKey": { "name": "userId", "type": "S" },
          "rangeKey": { "name": "roomId", "type": "S" },
          "projection": "ALL"
        }
      ]
    },
    {
      "tableName": "social-posts",
      "hashKey": { "name": "roomId", "type": "S" },
      "rangeKey": { "name": "postId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "authorId-postId-index",
          "hashKey": { "name": "authorId", "type": "S" },
          "rangeKey": { "name": "postId", "type": "S" },
          "projection": "ALL"
        }
      ]
    },
    {
      "tableName": "social-comments",
      "hashKey": { "name": "postId", "type": "S" },
      "rangeKey": { "name": "commentId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "social-likes",
      "hashKey": { "name": "targetId", "type": "S" },
      "rangeKey": { "name": "userId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "user-activity",
      "hashKey": { "name": "userId", "type": "S" },
      "rangeKey": { "name": "timestamp", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "social-outbox",
      "hashKey": { "name": "outboxId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "status-index",
          "hashKey": { "name": "status", "type": "S" },
          "rangeKey": { "name": "createdAt", "type": "S" },
          "projection": "ALL"
        }
      ]
    },
    {
      "tableName": "chat-messages",
      "hashKey": { "name": "channelId", "type": "S" },
      "rangeKey": { "name": "messageId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "_note": "Chat message persistence. messageId is base36(timestamp)+random for chronological sort. TTL attribute: ttl (epoch seconds, 90-day retention)."
    },
    {
      "tableName": "document-comments",
      "hashKey": { "name": "documentId", "type": "S" },
      "rangeKey": { "name": "commentId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "sectionId-timestamp-index",
          "hashKey": { "name": "sectionId", "type": "S" },
          "rangeKey": { "name": "timestamp", "type": "S" },
          "projection": "ALL"
        }
      ]
    },
    {
      "tableName": "section-reviews",
      "hashKey": { "name": "documentId", "type": "S" },
      "rangeKey": { "name": "reviewKey", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "userId-documentId-index",
          "hashKey": { "name": "userId", "type": "S" },
          "rangeKey": { "name": "documentId", "type": "S" },
          "projection": "ALL"
        },
        {
          "indexName": "sectionId-timestamp-index",
          "hashKey": { "name": "sectionId", "type": "S" },
          "rangeKey": { "name": "timestamp", "type": "S" },
          "projection": "ALL"
        }
      ]
    },
    {
      "tableName": "section-items",
      "hashKey": { "name": "sectionKey", "type": "S" },
      "rangeKey": { "name": "itemId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "assignee-status-index",
          "hashKey": { "name": "assignee", "type": "S" },
          "rangeKey": { "name": "status", "type": "S" },
          "projection": "ALL"
        },
        {
          "indexName": "documentId-index",
          "hashKey": { "name": "documentId", "type": "S" },
          "projection": "ALL"
        }
      ]
    },
    {
      "tableName": "document-sections",
      "hashKey": { "name": "documentId", "type": "S" },
      "rangeKey": { "name": "sectionId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "document-video-sessions",
      "hashKey": { "name": "documentId", "type": "S" },
      "rangeKey": { "name": "sessionId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "pipeline-definitions",
      "hashKey": { "name": "userId", "type": "S" },
      "rangeKey": { "name": "pipelineId", "type": "S" },
      "billing": "PAY_PER_REQUEST"
    },
    {
      "tableName": "pipeline-runs",
      "hashKey": { "name": "pipelineId", "type": "S" },
      "rangeKey": { "name": "runId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "status-startedAt-index",
          "hashKey": { "name": "status", "type": "S" },
          "rangeKey": { "name": "startedAt", "type": "S" },
          "projection": "ALL"
        },
        {
          "indexName": "triggeredBy-startedAt-index",
          "hashKey": { "name": "triggeredBy", "type": "S" },
          "rangeKey": { "name": "startedAt", "type": "S" },
          "projection": "ALL"
        }
      ],
      "_note": "TTL attribute: ttl (epoch seconds). Set by application for auto-expiry of old runs."
    },
    {
      "tableName": "document-types",
      "hashKey": { "name": "typeId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "_note": "Phase 51 Phase A — schema definitions for typed documents. Each DocumentType describes fields, validation, and display modes. Used by auto-form generator."
    },
    {
      "tableName": "typed-documents",
      "hashKey": { "name": "documentId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "typeId-createdAt-index",
          "hashKey": { "name": "typeId", "type": "S" },
          "rangeKey": { "name": "createdAt", "type": "S" },
          "projection": "ALL"
        }
      ],
      "_note": "Phase 51 Phase A — instances conforming to DocumentType schemas. GSI on typeId enables efficient list-by-type queries (currently Scan fallback in code, GSI provisioned for future)."
    },
    {
      "tableName": "pipeline-dlq",
      "hashKey": { "name": "messageId", "type": "S" },
      "billing": "PAY_PER_REQUEST",
      "gsi": [
        {
          "indexName": "failedAt-index",
          "hashKey": { "name": "status", "type": "S" },
          "rangeKey": { "name": "failedAt", "type": "S" },
          "projection": "ALL"
        }
      ],
      "_note": "TTL attribute: ttl (epoch seconds, 30-day retention). DLQ entries auto-expire."
    }
  ]
}
