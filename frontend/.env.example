# Cognito User Pool (already provisioned — values are fixed)
VITE_COGNITO_USER_POOL_ID=us-east-1_1cBzDswEa
VITE_COGNITO_CLIENT_ID=4bcsu1t495schc9fi25ompnv9j

# WebSocket gateway URL (e.g. wss://gateway.example.com or ws://localhost:8080)
VITE_WS_URL=ws://localhost:8080

# OPTIONAL (legacy) — only needed when bypassing the login form for local dev.
# Leave blank when using the in-app login form (the default).
VITE_COGNITO_TOKEN=

# Optional: channel to connect to on startup (default: general)
VITE_DEFAULT_CHANNEL=general

# Social API base URL (e.g. http://localhost:3001 or https://api.example.com)
VITE_SOCIAL_API_URL=http://localhost:3001

# Pipeline event source. Default 'mock' uses the in-browser MockExecutor
# (Phase 1). Switch to 'websocket' once Phase 4 wires the gateway bridge to
# distributed-core's PipelineModule — at which point real LLM events stream
# from the backend.
# Valid: 'mock' | 'websocket'
VITE_PIPELINE_SOURCE=mock
